{
  "_comment": "SPL 3.0 Cookbook Catalog — single source of truth for all recipes.",
  "_schema": {
    "is_active":        "bool   — included in default batch run (python cookbook/run_all.py)",
    "approval_status":  "string — new | approved | wip | disabled | rejected",
    "category":         "string — multimodal | agentic | basics | ...",
    "tier":             "int    — 1=Ollama only | 2=OpenAI key | 3=OpenRouter key | 4=both keys",
    "requires":         "list   — runtime prerequisites: ollama:<model>, env:VAR_NAME"
  },
  "recipes": [
    {
      "id":              "50",
      "name":            "Image Caption",
      "description":     "Describe / analyse / OCR an image using Gemma4 vision (IMAGE → TEXT)",
      "args":            ["python", "cookbook/50_image_caption/run.py",
                          "--image", "cookbook/50_image_caption/sample/photo.jpg"],
      "dir":             "50_image_caption",
      "log":             "image_caption",
      "is_active":       true,
      "approval_status": "new",
      "category":        "multimodal",
      "tier":            1,
      "requires":        ["ollama:gemma4:e4b"]
    },
    {
      "id":              "51",
      "name":            "Audio Summary",
      "description":     "Transcribe / summarise / extract key points from audio (AUDIO → TEXT)",
      "args":            ["python", "cookbook/51_audio_summary/run.py",
                          "--audio", "cookbook/51_audio_summary/sample/clip.mp3"],
      "dir":             "51_audio_summary",
      "log":             "audio_summary",
      "is_active":       false,
      "approval_status": "new",
      "category":        "multimodal",
      "tier":            3,
      "requires":        ["env:OPENROUTER_API_KEY"]
