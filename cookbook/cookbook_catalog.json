      "log":             "text_to_image",
      "is_active":       false,
      "approval_status": "new",
      "category":        "multimodal",
      "tier":            2,
      "requires":        ["env:OPENAI_API_KEY"]
    },
    {
      "id":              "53",
      "name":            "Text to Speech",
      "description":     "Convert text to natural speech and save as audio file (TEXT → AUDIO)",
      "args":            ["python", "cookbook/53_text_to_speech/run.py",
                          "--text", "Welcome to SPL 3.0 multimodal support."],
      "dir":             "53_text_to_speech",
      "log":             "text_to_speech",
      "is_active":       false,
      "approval_status": "new",
      "category":        "multimodal",
      "tier":            2,
      "requires":        ["env:OPENAI_API_KEY"]
    },
    {
