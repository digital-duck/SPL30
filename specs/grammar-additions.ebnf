(* SPL 3.0 Grammar Additions — EBNF delta over SPL 2.0 *)
(* Base grammar: spl2-specification-v2.md              *)

(* ============================================================ *)
(* 1. IMPORT directive                                           *)
(* ============================================================ *)
(* Load workflow definitions from an external .spl file.        *)
(* Resolved at parse time relative to the current file.         *)

import_stmt = 'IMPORT' string_literal ';'? ;

(* ============================================================ *)
(* 2. CALL workflow (extended from SPL 2.0)                     *)
(* ============================================================ *)
(* SPL 2.0: CALL tool_fn(@arg) INTO @var  (Python @spl_tool)    *)
(* SPL 3.0: CALL workflow_name(@arg) INTO @var (WORKFLOW def)   *)
(*                                                               *)
(* The runtime resolves the callee name in priority order:       *)
(*   1. Registered @spl_tool (Python function)                  *)
(*   2. Local WorkflowRegistry                                   *)
(*   3. Hub workflow registry (via POST /tasks type=workflow)    *)
(*   4. Hub-to-Hub peering (peer_hub routing)                   *)

call_stmt = 'CALL' identifier '(' arg_list? ')' 'INTO' variable ';'? ;

arg_list = arg (',' arg)* ;
arg      = variable | literal | expression ;

(* ============================================================ *)
(* 3. CALL PARALLEL                                              *)
(* ============================================================ *)
(* Dispatch multiple sub-workflows concurrently.                 *)
(* Hub routes each to an available node (existing mechanism).    *)

call_parallel_stmt =
    'CALL' 'PARALLEL'
        parallel_call (',' parallel_call)*
    'END' ;

parallel_call = identifier '(' arg_list? ')' 'INTO' variable ;

(* ============================================================ *)
(* 4. COMMIT (clarification for composition context)             *)
(* ============================================================ *)
(* Unchanged syntax. In composition context:                     *)
(*   - 'complete' (default)  → OUTPUT returned to caller         *)
(*   - any other status      → WorkflowCompositionError raised   *)
(*                             in calling scope (EXCEPTION chan)  *)

commit_stmt = 'COMMIT' expression? ('WITH' commit_options)? ';'? ;
commit_options = commit_option (',' commit_option)* ;
commit_option  = identifier '=' literal ;

(* ============================================================ *)
(* 5. New keywords                                               *)
(* ============================================================ *)

new_keywords = 'IMPORT' | 'PARALLEL'
             | 'NONE'   | 'NULL'       (* null literal — aliases  *)
             | 'IMAGE'  | 'AUDIO' | 'VIDEO'  (* multimodal types  *)
             ;

(* ============================================================ *)
(* 7. Extended Type System (SPL 3.0)                            *)
(* ============================================================ *)
(*                                                               *)
(* SPL 2.0 types (unchanged, all remain valid):                 *)
(*   TEXT | NUMBER | BOOL | LIST | MAP | STORAGE                 *)
(*                                                               *)
(* SPL 3.0 additions:                                           *)
(*                                                               *)
(*   INT        integer; precision split from NUMBER             *)
(*   FLOAT      float; precision split from NUMBER               *)
(*   NONE/NULL  first-class null literal (SQL + Python style)    *)
(*   SET        unordered unique collection; {a, b, c} literal   *)
(*   IMAGE      multimodal image input/output                    *)
(*   AUDIO      multimodal audio input/output                    *)
(*   VIDEO      multimodal video input/output                    *)
(*   DATACLASS  typed named-field struct (v3.1, planned)         *)
(*                                                               *)
(* Disambiguation rule for { } literals:                        *)
(*   {}          → empty MAP  (consistent with Python)           *)
(*   {k: v, ...} → MAP        (colon after first element)        *)
(*   {a, b, ...} → SET        (comma after first element)        *)

type_annotation =
      'TEXT'    | 'STR'
    | 'INT'     | 'INTEGER'
    | 'FLOAT'
    | 'NUMBER'                    (* v2.0 compat alias *)
    | 'BOOL'    | 'BOOLEAN'
    | 'LIST'
    | 'SET'
    | 'MAP'     | 'DICT'
    | 'NONE'    | 'NULL'
    | 'IMAGE'   | 'AUDIO' | 'VIDEO'
    | 'STORAGE' '(' identifier ',' string_literal ')'
    | 'DATACLASS'                 (* v3.1 — paired with CREATE TYPE *)
    ;

(* ============================================================ *)
(* 8. NONE literal                                              *)
(* ============================================================ *)
(*                                                               *)
(* NONE is a first-class expression, assignable to any variable.*)
(*                                                               *)
(*   @result := NONE                                             *)
(*   EVALUATE @result WHEN = NONE THEN ...  END                  *)
(*   INPUT: @threshold FLOAT DEFAULT NONE                        *)
(*                                                               *)
(* NONE serializes to the empty string '' in the string-based   *)
(* variable store.  is_none_value() in spl3/types.py            *)
(* centralizes this convention.                                  *)

none_literal = 'NONE' | 'NULL' ;

(* ============================================================ *)
(* 9. SET literal                                               *)
(* ============================================================ *)
(*                                                               *)
(* Syntax mirrors Python set literals.  The parser disambiguates*)
(* { } by peeking at the token after the first element:         *)
(*                                                               *)
(*   {expr, expr, ...}    → SetLiteral                          *)
(*   {expr: expr, ...}    → MapLiteral  (colon present)         *)
(*   {}                   → MapLiteral  (empty — MAP by default) *)
(*                                                               *)
(* At runtime, SetLiteral serializes as a JSON array with        *)
(* duplicates removed and elements sorted for stable output.     *)
(*                                                               *)
(*   @seen := {'apple', 'banana', 'apple'}   -- stores ["apple","banana"] *)

set_literal  = '{' set_elements '}' ;
set_elements = expression (',' expression)+ ;  (* ≥2 disambiguates vs MAP *)

(* ============================================================ *)
(* 10. Multimodal types — IMAGE, AUDIO, VIDEO                   *)
(* ============================================================ *)
(*                                                               *)
(* Multimodal params hold a file path (string) or base64 blob.  *)
(* The LLM adapter (Liquid AI LFM or any multimodal provider)   *)
(* is responsible for encoding the value before inference.       *)
(*                                                               *)
(*   WORKFLOW describe_image                                     *)
(*       INPUT:  @photo IMAGE, @question TEXT                    *)
(*       OUTPUT: @answer TEXT                                    *)
(*   DO                                                          *)
(*       GENERATE vision_describe(@photo, @question) INTO @answer*)
(*       COMMIT @answer                                          *)
(*   END                                                         *)
(*                                                               *)
(* The executor passes IMAGE/AUDIO/VIDEO params to the adapter   *)
(* as-is (file path string or data URI).  Multimodal encoding    *)
(* is an adapter responsibility, not a language responsibility.  *)

multimodal_type = 'IMAGE' | 'AUDIO' | 'VIDEO' ;

(* ============================================================ *)
(* 11. DATACLASS — v3.1 planned                                 *)
(* ============================================================ *)
(*                                                               *)
(* Python developers expect named, typed record types.          *)
(* DATACLASS bridges SPL's MAP type with Python dataclasses.     *)
(*                                                               *)
(* Definition:                                                   *)
(*   CREATE TYPE Review AS (                                     *)
(*       score   FLOAT,                                          *)
(*       verdict TEXT,                                           *)
(*       passed  BOOL                                            *)
(*   )                                                           *)
(*                                                               *)
(* Usage:                                                        *)
(*   WORKFLOW evaluate_code                                       *)
(*       INPUT:  @code TEXT                                      *)
(*       OUTPUT: @review Review                                  *)
(*   DO                                                          *)
(*       GENERATE reviewer(@code)                                *)
(*           WITH FORMAT JSON SCHEMA Review INTO @review         *)
(*       COMMIT @review                                          *)
(*   END                                                         *)
(*                                                               *)
(* At runtime DATACLASS instances serialize as JSON objects      *)
(* (same wire format as MAP); the type annotation drives schema  *)
(* injection into the GENERATE FORMAT JSON SCHEMA clause.        *)
(*                                                               *)
(* Note: requires CREATE TYPE statement — not in SPL 3.0.       *)
(*       Planned for SPL 3.1 once CALL composition is stable.   *)

create_type_stmt =
    'CREATE' 'TYPE' identifier 'AS' '('
        typed_field (',' typed_field)*
    ')' ';'? ;

typed_field = identifier type_annotation ;

(* ============================================================ *)
(* 6. Hub protocol extension (protocol level, not SPL syntax)   *)
(* ============================================================ *)
(*                                                               *)
(* Runtime unit of execution: WorkflowInvocationEvent           *)
(*                                                               *)
(* Key design principle:                                         *)
(*   Definition  = static, shared, named (.spl WORKFLOW block)  *)
(*   Invocation  = dynamic, isolated, identified by event_id    *)
(*                                                               *)
(* Two concurrent callers of 'review_code' produce two          *)
(* independent events with completely isolated variable scopes.  *)
(* Name collision (design-time) is irrelevant at runtime        *)
(* because identity is event_id (UUID), not workflow name.      *)
(*                                                               *)
(* OS analogy:                                                   *)
(*   workflow definition      ≈  program binary (shared/static) *)
(*   WorkflowInvocationEvent  ≈  process (isolated, has PID)    *)
(*   event_id                 ≈  PID                            *)
(*   parent_event_id          ≈  parent PID (fork lineage)      *)
(*   Hub event log            ≈  /proc (kernel process table)   *)
(*                                                               *)
(* POST /tasks payload (SPL 3.0 extension):                     *)
(*                                                               *)
(*   {                                                           *)
(*     -- SPL 2.0 fields (unchanged) --                         *)
(*     "model":         "string",                               *)
(*     "prompt":        "string",                               *)
(*     "system_role":   "string | null",                        *)
(*     "temperature":   "float | null",                         *)
(*     "max_tokens":    "integer | null",                       *)
(*     "node_requirements": { "min_tier": int, ... },           *)
(*     "session_key_id": "string | null",                       *)
(*                                                               *)
(*     -- SPL 3.0 additions (ignored by SPL 2.0 nodes) --       *)
(*     "type":            "workflow",    <- was implicit         *)
(*     "workflow":        "review_code", <- registry lookup key  *)
(*     "namespace":       "python",      <- IMPORT AS alias     *)
(*     "args":            {"code": "..."}, <- INPUT bindings    *)
(*     "event_id":        "uuid",        <- idempotency key     *)
(*     "parent_event_id": "uuid | null", <- call tree linkage   *)
(*     "requester_id":    "string",      <- attribution/billing  *)
(*     "peer_hub":        "https://...", <- Hub-to-Hub routing   *)
(*   }                                                           *)
(*                                                               *)
(* GET /tasks/{event_id} response (SPL 3.0 additions):          *)
(*                                                               *)
(*   {                                                           *)
(*     -- SPL 2.0 fields --                                     *)
(*     "task_id":    "uuid",                                     *)
(*     "status":     "pending | running | complete | failed",   *)
(*     "result":     "string",                                   *)
(*     "tokens_in":  integer,                                   *)
(*     "tokens_out": integer,                                    *)
(*     "latency_ms": integer,                                    *)
(*     "node_id":    "string",                                   *)
(*                                                               *)
(*     -- SPL 3.0 additions --                                  *)
(*     "event_id":      "uuid",          <- same as task_id     *)
(*     "commit_status": "string",        <- COMMIT status value  *)
(*     "workflow":      "review_code",   <- which workflow ran   *)
(*     "requester_id":  "string"         <- for audit trail      *)
(*   }                                                           *)
(*                                                               *)
(* Event log queries (new Hub endpoints):                        *)
(*                                                               *)
(*   GET /events?workflow=review_code&status=running            *)
(*   GET /events?parent=abc-001           <- full call tree     *)
(*   GET /events?requester=user-42&since=1h  <- audit trail     *)
(*                                                               *)
(* Backward compatible: SPL 2.0 nodes ignore unknown fields.    *)
(* Re-submitting a known event_id returns cached output          *)
(* (idempotency — same as retry semantics in SPL 2.0).          *)
